{
  "name": "decoder-qr-pago-movil",
  "version": "1.0.4",
  "description": "Decodifica códigos QR de Pago Móvil (Suiche 7B). Compatible con 58 bancos. Funciona en Node.js, Bun y navegador.",
  "license": "MIT",
  "type": "module",
  "main": "dist/decoder-qr-pago-movil.cjs",
  "module": "dist/decoder-qr-pago-movil.browser.js",
  "browser": "dist/decoder-qr-pago-movil.browser.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/decoder-qr-pago-movil.browser.js",
      "import": "./dist/decoder-qr-pago-movil.js",
      "require": "./dist/decoder-qr-pago-movil.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "bun run scripts/prebuild.ts",
    "build": "bun run prebuild && bun run build:esm && bun run build:cjs && bun run build:browser && bun run build:types",
    "build:esm": "bun build src/index.ts --outfile=dist/decoder-qr-pago-movil.js --target=node --format=esm --packages=bundle",
    "build:cjs": "bun build src/index.ts --outfile=dist/decoder-qr-pago-movil.cjs --target=node --format=cjs --packages=bundle",
    "build:browser": "bun build src/index.ts --outfile=dist/decoder-qr-pago-movil.browser.js --target=browser --format=esm --packages=bundle",
    "build:types": "tsc -p tsconfig.types.json",
    "start": "bun run index.ts",
    "test": "bun run index.ts",
    "prepublishOnly": "bun run build",
    "prepack": "bun run build",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node-forge": "^1.3.14",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "blowfish": "^1.0.1",
    "node-forge": "^1.4.0"
  }
}
