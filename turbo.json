{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "prebuild": {
      "outputs": ["src/decode-qr-pago-movil/keys-processed.ts"]
    },
    "build": {
      "dependsOn": ["prebuild", "^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "scripts/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
